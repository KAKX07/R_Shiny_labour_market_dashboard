#Compute self employment share per country / year
#We reconstruct the total by summing mutually exclusive sectors
data_emp_self <- read_csv("OECD_EMP_PER_SECTOR.csv") %>%
filter(TRANSACTION %in% c("EMP", "SELF")) %>%
filter(ACTIVITY %in% secteurs_exclusifs) %>%  #same sectors as data_emp_sector
select(
ISO        = REF_AREA,
Country    = `Zone de référence`,
Type       = TRANSACTION,
Period     = TIME_PERIOD,
Employment = OBS_VALUE
) %>%
filter(ISO %in% europe_iso) %>%
filter(!is.na(Employment)) %>%
group_by(ISO, Country, Type, Period) %>%
summarise(Employment = sum(Employment, na.rm = TRUE), .groups = "drop") %>%
pivot_wider(names_from = Type, values_from = Employment) %>%
mutate(Self_Employment_Share = SELF / EMP * 100)
data_emp_self
# ==============================================================================
# 3. Final join : AI impact on labour market (core of page 2)
# ==============================================================================
#Aggregate employment growth across all age groups before joining
#This avoids the approximation of filtering on a single age group
data_emp_growth_15_64 <- total_data_emp %>%
group_by(ISO, Country, Period) %>%
summarise(Employement_Total = sum(Employement, na.rm = TRUE), .groups = "drop") %>%
group_by(ISO, Country) %>%
arrange(Period) %>%
mutate(
Emp_Growth = (Employement_Total - lag(Employement_Total)) / lag(Employement_Total) * 100
) %>%
ungroup()
data_emp_growth_15_64
#Join AI adoption with wage growth and employment growth
#Common period between AI and labour datasets : 2017-2024
data_ai_labour <- data_ai %>%
left_join(data_avg_wage %>% select(ISO, Country, Period, AVG_WAGE, Wage_Growth),
by = c("ISO", "Country", "Period")) %>%
left_join(data_emp_growth_15_64 %>% select(ISO, Country, Period, Emp_Growth),
by = c("ISO", "Country", "Period")) %>%
drop_na(pct_AI, AVG_WAGE)
data_ai_labour
# ==============================================================================
# 4. Save all prepared data for the Shiny app
# ==============================================================================
save(
total_data_emp,
data_unemp,
data_avg_wage,
data_ai,
data_emp_sector,
data_skills,
data_labour,
data_emp_growth,
data_emp_age_share,
data_emp_self,
data_emp_growth_15_64,
data_ai_labour,
file = "data_prepared.RData"
)
message("data_prep.R done — data_prepared.RData saved")
# ==============================================================================
# app.R
# European Labour Market Dashboard
# ==============================================================================
library(shiny)
library(shinydashboard)
library(tidyverse)
library(ggplot2)
library(shinyWidgets)
#Load all prepared data
load("data_prepared.RData")
#Helper function — pickerInput with consistent Excel-style options
make_picker <- function(id, label, choices, selected = choices) {
pickerInput(
inputId  = id,
label    = label,
choices  = sort(choices),
selected = selected,
multiple = TRUE,
options  = pickerOptions(
actionsBox         = TRUE,        #Select All / Deselect All buttons
liveSearch         = TRUE,        #search bar inside the dropdown
selectedTextFormat = "count > 3"  #shows count when more than 3 selected
)
)
}
# ==============================================================================
# UI
# ==============================================================================
ui <- dashboardPage(
skin = "blue",
#Header
dashboardHeader(title = "European Labour Market"),
#Sidebar — navigation only, no filters
dashboardSidebar(
sidebarMenu(
menuItem("Overview",           tabName = "overview"),
menuItem("AI & Labour",        tabName = "ai"),
menuItem("Employment Sectors", tabName = "sectors"),
menuItem("Skills",             tabName = "skills")
)
),
#Body — one tabItem per page
dashboardBody(
tabItems(
# ------------------------------------------------------------
# Page 1 — Overview
# ------------------------------------------------------------
tabItem(
tabName = "overview",
h2("Labour Market Overview"),
#Filters — Excel-style pickers directly on the page
fluidRow(
box(width = 6, status = "primary",
make_picker("ov_country", "Select countries",
choices  = unique(total_data_emp$Country),
selected = c("France", "Allemagne", "Italie", "Espagne", "Portugal"))),
box(width = 6, status = "primary",
make_picker("ov_year", "Select years",
choices  = unique(total_data_emp$Period),
selected = unique(total_data_emp$Period)))
),
#KPI cards
fluidRow(
valueBoxOutput("kpi_emp",   width = 4),
valueBoxOutput("kpi_unemp", width = 4),
valueBoxOutput("kpi_wage",  width = 4)
),
#Charts
fluidRow(
box(title = "Unemployment Rate over time",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_unemp_rate")),
box(title = "Average Wage evolution (index base 100 = 2000)",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_wage"))
),
fluidRow(
box(title = "Employment share by Age Group (latest year)",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_age_share")),
box(title = "Employment Growth YoY — Age 25-54",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_emp_growth"))
)
),
# ------------------------------------------------------------
# Page 2 — AI & Labour
# ------------------------------------------------------------
tabItem(
tabName = "ai",
h2("AI Adoption & Labour Market Impact"),
#Filters — year picker + country picker
fluidRow(
box(width = 6, status = "primary",
make_picker("ai_country", "Select countries",
choices  = unique(data_ai_labour$Country),
selected = unique(data_ai_labour$Country))),
box(width = 6, status = "primary",
make_picker("ai_year", "Select year for scatter plots",
choices  = unique(data_ai_labour$Period),
selected = max(data_ai_labour$Period)))
),
fluidRow(
box(title = "AI Adoption rate by country",
status = "primary", solidHeader = TRUE, width = 12,
plotOutput("plot_ai_adoption"))
),
fluidRow(
box(title = "AI Adoption vs Average Wage",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_ai_wage")),
box(title = "AI Adoption vs Employment Growth",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_ai_emp"))
)
),
# ------------------------------------------------------------
# Page 3 — Employment by Sector
# ------------------------------------------------------------
tabItem(
tabName = "sectors",
h2("Employment by Sector"),
#Filters
fluidRow(
box(width = 6, status = "primary",
make_picker("sec_country", "Select countries",
choices  = unique(data_emp_sector$Country),
selected = c("France", "Allemagne", "Italie", "Espagne", "Pologne"))),
box(width = 6, status = "primary",
make_picker("sec_year", "Select years",
choices  = unique(data_emp_sector$Period),
selected = unique(data_emp_sector$Period)))
),
fluidRow(
box(title = "Employment distribution by sector (latest selected year)",
status = "primary", solidHeader = TRUE, width = 12,
plotOutput("plot_sector_share"))
),
fluidRow(
box(title = "Self-employment share by country",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_self_emp")),
box(title = "Sector employment over time",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_sector_time"))
)
),
# ------------------------------------------------------------
# Page 4 — Skills
# ------------------------------------------------------------
tabItem(
tabName = "skills",
h2("Skills Shortage & Demand"),
#Filter
fluidRow(
box(width = 6, status = "primary",
make_picker("sk_country", "Select countries",
choices  = unique(data_skills$Country),
selected = unique(data_skills$Country)))
),
fluidRow(
box(title = "Skill shortage by category (avg across selected countries)",
status = "primary", solidHeader = TRUE, width = 12,
plotOutput("plot_skills_shortage"))
),
fluidRow(
box(title = "Top 5 skills in shortage",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_skills_top")),
box(title = "Top 5 skills in surplus",
status = "primary", solidHeader = TRUE, width = 6,
plotOutput("plot_skills_bottom"))
)
)
)
)
)
# ==============================================================================
# SERVER
# ==============================================================================
server <- function(input, output, session) {
# ------------------------------------------------------------
# Page 1 — Reactive filtered datasets
# ------------------------------------------------------------
#Filter employment data by selected countries and years
emp_filtered <- reactive({
total_data_emp %>%
filter(Country %in% input$ov_country,
Period  %in% as.numeric(input$ov_year))
})
#Filter labour data (unemployment rate)
labour_filtered <- reactive({
data_labour %>%
filter(Country %in% input$ov_country,
Period  %in% as.numeric(input$ov_year))
})
#Filter wage data
wage_filtered <- reactive({
data_avg_wage %>%
filter(Country %in% input$ov_country,
Period  %in% as.numeric(input$ov_year))
})
# ------------------------------------------------------------
# Page 1 — KPI cards
# ------------------------------------------------------------
output$kpi_emp <- renderValueBox({
val <- emp_filtered() %>%
filter(Period == max(Period)) %>%
summarise(total = sum(Employement, na.rm = TRUE)) %>%
pull(total)
valueBox(
value    = paste0(round(val / 1000, 1), "M"),
subtitle = "Total Employment (latest selected year)",
icon     = icon("briefcase"),
color    = "blue"
)
})
output$kpi_unemp <- renderValueBox({
val <- labour_filtered() %>%
filter(Period == max(Period)) %>%
summarise(rate = mean(Unemployment_Rate, na.rm = TRUE)) %>%
pull(rate)
valueBox(
value    = paste0(round(val, 1), "%"),
subtitle = "Avg Unemployment Rate (latest selected year)",
icon     = icon("user-times"),
color    = "red"
)
})
output$kpi_wage <- renderValueBox({
val <- wage_filtered() %>%
filter(Period == max(Period)) %>%
summarise(wage = mean(AVG_WAGE, na.rm = TRUE)) %>%
pull(wage)
valueBox(
value    = paste0("$", format(round(val), big.mark = ",")),
subtitle = "Avg Annual Wage in USD PPP (latest selected year)",
icon     = icon("dollar-sign"),
color    = "green"
)
})
# ------------------------------------------------------------
# Page 1 — Charts
# ------------------------------------------------------------
#Unemployment rate over time — line chart
output$plot_unemp_rate <- renderPlot({
labour_filtered() %>%
group_by(Country, Period) %>%
summarise(Rate = mean(Unemployment_Rate, na.rm = TRUE), .groups = "drop") %>%
ggplot(aes(x = Period, y = Rate, color = Country)) +
geom_line(size = 1) +
geom_point(size = 2) +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "Year", y = "Unemployment Rate (%)", color = "Country")
})
#Wage index over time — line chart
output$plot_wage <- renderPlot({
wage_filtered() %>%
ggplot(aes(x = Period, y = Wage_Index, color = Country)) +
geom_line(size = 1) +
geom_hline(yintercept = 100, linetype = "dashed", color = "grey50") +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "Year", y = "Wage Index (base 100 = 2010)", color = "Country")
})
#Employment share by age group — stacked bar (latest selected year)
output$plot_age_share <- renderPlot({
data_emp_age_share %>%
filter(Country %in% input$ov_country,
Period  == max(as.numeric(input$ov_year))) %>%
ggplot(aes(x = reorder(Country, Age_Share), y = Age_Share, fill = Age)) +
geom_col() +
coord_flip() +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "", y = "Share of Employment (%)", fill = "Age group")
})
#Employment growth YoY — line chart (age 25-54 only)
output$plot_emp_growth <- renderPlot({
data_emp_growth %>%
filter(Country %in% input$ov_country,
Period  %in% as.numeric(input$ov_year),
Age == "Y25T54") %>%
ggplot(aes(x = Period, y = Emp_Growth, color = Country)) +
geom_line(size = 1) +
geom_hline(yintercept = 0, linetype = "dashed", color = "grey50") +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "Year", y = "Employment Growth YoY (%)", color = "Country")
})
# ------------------------------------------------------------
# Page 2 — AI charts
# ------------------------------------------------------------
#AI adoption by country — bar chart filtered by selected year and countries
output$plot_ai_adoption <- renderPlot({
data_ai_labour %>%
filter(Country %in% input$ai_country,
Period  %in% as.numeric(input$ai_year)) %>%
drop_na(pct_AI) %>%
ggplot(aes(x = reorder(Country, pct_AI), y = pct_AI, fill = Country)) +
geom_col() +
coord_flip() +
theme_minimal() +
theme(panel.grid.minor = element_blank(),
legend.position = "none") +
labs(x = "", y = "% of businesses using AI")
})
#AI adoption vs average wage — scatter plot (latest selected year)
output$plot_ai_wage <- renderPlot({
data_ai_labour %>%
filter(Country %in% input$ai_country,
Period  == max(as.numeric(input$ai_year))) %>%
drop_na(pct_AI, AVG_WAGE) %>%
ggplot(aes(x = pct_AI, y = AVG_WAGE, color = Country, label = Country)) +
geom_point(size = 4) +
geom_text(vjust = -0.8, size = 3) +
geom_smooth(aes(group = 1), method = "lm", se = FALSE,
color = "grey50", linetype = "dashed") +
theme_minimal() +
theme(panel.grid.minor = element_blank(),
legend.position = "none") +
labs(x = "AI Adoption (%)", y = "Average Wage (USD PPP)")
})
#AI adoption vs employment growth — scatter plot (latest selected year)
output$plot_ai_emp <- renderPlot({
data_ai_labour %>%
filter(Country %in% input$ai_country,
Period  == max(as.numeric(input$ai_year))) %>%
drop_na(pct_AI, Emp_Growth) %>%
ggplot(aes(x = pct_AI, y = Emp_Growth, color = Country, label = Country)) +
geom_point(size = 4) +
geom_text(vjust = -0.8, size = 3) +
geom_hline(yintercept = 0, linetype = "dashed", color = "grey50") +
geom_smooth(aes(group = 1), method = "lm", se = FALSE,
color = "grey50", linetype = "dashed") +
theme_minimal() +
theme(panel.grid.minor = element_blank(),
legend.position = "none") +
labs(x = "AI Adoption (%)", y = "Employment Growth (%)")
})
# ------------------------------------------------------------
# Page 3 — Sector charts
# ------------------------------------------------------------
#Filter sector data — force numeric conversion to match Period column type
sector_filtered <- reactive({
data_emp_sector %>%
filter(Country %in% input$sec_country,
Period  %in% as.numeric(input$sec_year))
})
#Employment by sector — stacked bar (latest selected year)
output$plot_sector_share <- renderPlot({
sector_filtered() %>%
filter(Period == max(Period)) %>%
ggplot(aes(x = reorder(Country, Employment), y = Employment, fill = Sector_label)) +
geom_col() +
coord_flip() +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "", y = "Employment (thousands)", fill = "Sector")
})
#Self employment share over time — line chart
output$plot_self_emp <- renderPlot({
data_emp_self %>%
filter(Country %in% input$sec_country,
Period  %in% as.numeric(input$sec_year)) %>%
ggplot(aes(x = Period, y = Self_Employment_Share, color = Country)) +
geom_line(size = 1) +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "Year", y = "Self-employment share (%)", color = "Country")
})
#Sector employment over time — aggregated across selected countries
output$plot_sector_time <- renderPlot({
sector_filtered() %>%
group_by(Sector_label, Period) %>%
summarise(Employment = sum(Employment, na.rm = TRUE), .groups = "drop") %>%
ggplot(aes(x = Period, y = Employment, color = Sector_label)) +
geom_line(size = 1) +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "Year", y = "Employment (thousands)", color = "Sector")
})
# ------------------------------------------------------------
# Page 4 — Skills charts
# ------------------------------------------------------------
#All skills shortage — horizontal bar chart colored by sign
output$plot_skills_shortage <- renderPlot({
data_skills %>%
filter(Country %in% input$sk_country) %>%
group_by(Skill) %>%
summarise(Shortage = mean(Shortage, na.rm = TRUE), .groups = "drop") %>%
mutate(Sign = ifelse(Shortage > 0, "Shortage", "Surplus")) %>%
ggplot(aes(x = reorder(Skill, Shortage), y = Shortage, fill = Sign)) +
geom_col() +
scale_fill_manual(values = c("Shortage" = "#e74c3c", "Surplus" = "#3498db")) +
coord_flip() +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "", y = "Shortage indicator", fill = "")
})
#Top 5 skills in shortage
output$plot_skills_top <- renderPlot({
data_skills %>%
filter(Country %in% input$sk_country) %>%
group_by(Skill) %>%
summarise(Shortage = mean(Shortage, na.rm = TRUE), .groups = "drop") %>%
slice_max(Shortage, n = 5) %>%
ggplot(aes(x = reorder(Skill, Shortage), y = Shortage)) +
geom_col(fill = "#e74c3c") +
coord_flip() +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "", y = "Shortage indicator")
})
#Top 5 skills in surplus
output$plot_skills_bottom <- renderPlot({
data_skills %>%
filter(Country %in% input$sk_country) %>%
group_by(Skill) %>%
summarise(Shortage = mean(Shortage, na.rm = TRUE), .groups = "drop") %>%
slice_min(Shortage, n = 5) %>%
ggplot(aes(x = reorder(Skill, Shortage), y = Shortage)) +
geom_col(fill = "#3498db") +
coord_flip() +
theme_minimal() +
theme(panel.grid.minor = element_blank()) +
labs(x = "", y = "Surplus indicator")
})
}
# ==============================================================================
# Run the app
# ==============================================================================
shinyApp(ui = ui, server = server)
# European Labour Market Dashboard
### An OECD Data Analysis — Block 7 Assignment
---
## Context
This dashboard was built as part of a data visualization course assignment. The scenario is the following : **you are a data analyst at the OECD**, and the Secretary General has asked your department to prepare a dashboard for a high-level meeting with European ministries on the evolution of the labour market.
